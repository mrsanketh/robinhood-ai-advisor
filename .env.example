# ══════════════════════════════════════════════════════
# Robinhood AI Advisor — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub
# ══════════════════════════════════════════════════════

# ── Robinhood Credentials ─────────────────────────────
# Your Robinhood login email and password
ROBINHOOD_USERNAME=your_robinhood_email@gmail.com
ROBINHOOD_PASSWORD=your_robinhood_password

# ── Finnhub API ───────────────────────────────────────
# Free API key from https://finnhub.io
# Sign up → Dashboard → API Key
FINNHUB_API_KEY=your_finnhub_api_key

# ── Google Gemini API ─────────────────────────────────
# Free API key from https://aistudio.google.com
# Create API Key → Copy
GEMINI_API_KEY=your_gemini_api_key

# ── Telegram Bot ──────────────────────────────────────
# Create bot via @BotFather on Telegram
# /newbot → follow instructions → copy token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Your personal Telegram chat ID
# Get it by messaging @userinfobot on Telegram
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Scoring Weights ───────────────────────────────────
# These control how F, M, S signals are weighted
# Must add up to 1.0
FUNDAMENTAL_WEIGHT=0.40
MOMENTUM_WEIGHT=0.35
SENTIMENT_WEIGHT=0.25

# ── Score Thresholds ──────────────────────────────────
# Stocks above BUY_SCORE_THRESHOLD are buy candidates
# Stocks below SELL_SCORE_THRESHOLD are rotate candidates
BUY_SCORE_THRESHOLD=7.0
SELL_SCORE_THRESHOLD=5.0
